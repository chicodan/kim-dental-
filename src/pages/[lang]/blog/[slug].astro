---
import MainLayout from "../../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";
import { LOCALES, type Locale } from "../../../i18n/locales";
import { setLocale } from "../../../paraglide/runtime.js";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  const now = new Date();
  const posts = allPosts.filter((p) => p.data.pubDate <= now);
  return LOCALES.flatMap((lang) =>
    posts.map((post) => ({
      params: { lang, slug: post.slug },
      props: { post },
    }))
  );
}

const lang = Astro.params.lang as Locale;
setLocale(lang);

const { post } = Astro.props;
const { Content } = await post.render();

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<MainLayout>
  <!-- Breadcrumb -->
  <div class="max-w-6xl mx-auto px-4 pt-8 pb-2">
    <nav class="text-sm text-gray-500">
      <a href={`/${lang}/`} class="hover:text-brand-purple transition-colors">Home</a>
      <span class="mx-2">›</span>
      <a href={`/${lang}/blog`} class="hover:text-brand-purple transition-colors">Blog</a>
      <span class="mx-2">›</span>
      <span class="text-gray-800">{post.data.title}</span>
    </nav>
  </div>

  <!-- Article -->
  <article class="max-w-6xl mx-auto px-4 py-10">
    <div class="max-w-3xl mx-auto">

      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mb-5">
        {post.data.tags.map((tag) => (
          <span class="text-xs font-medium bg-brand-purple/10 text-brand-purple px-3 py-1 rounded-full">
            {tag}
          </span>
        ))}
      </div>

      <!-- Title -->
      <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-brand-purple leading-tight mb-5">
        {post.data.title}
      </h1>

      <!-- Meta -->
      <div class="flex items-center gap-3 text-sm text-gray-500 mb-10 pb-8 border-b border-gray-200">
        <div class="w-9 h-9 rounded-full bg-brand-purple flex items-center justify-center text-white text-xs font-bold shrink-0">
          DK
        </div>
        <div>
          <span class="font-medium text-gray-700">{post.data.author}</span>
          <span class="mx-1">·</span>
          {formatDate(post.data.pubDate)}
        </div>
      </div>

      <!-- Content -->
      <div class="blog-content">
        <Content />
      </div>

      <!-- Back to Blog -->
      <div class="mt-14 pt-8 border-t border-gray-200">
        <a
          href={`/${lang}/blog`}
          class="inline-flex items-center gap-2 text-brand-purple font-medium hover:text-accent-teal transition-colors"
        >
          ← Back to Blog
        </a>
      </div>
    </div>
  </article>

  <!-- Book Appointment CTA -->
  <section class="section-breakout bg-brand-purple py-14">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h2 class="font-heading text-3xl font-bold text-white mb-3">
        Ready to Take the Next Step?
      </h2>
      <p class="text-white/80 text-lg mb-8 max-w-xl mx-auto">
        Dr. Kim and our team are here to answer your questions and provide the personalized care you deserve.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`/${lang}/book`}
          class="inline-flex items-center justify-center gap-2 bg-accent-gold text-white px-7 py-3.5 rounded-lg font-semibold hover:bg-opacity-90 transition-colors"
        >
          Book an Appointment
        </a>
        <a
          href="tel:+12015991888"
          class="inline-flex items-center justify-center gap-2 bg-white/10 border border-white/30 text-white px-7 py-3.5 rounded-lg font-semibold hover:bg-white/20 transition-colors"
        >
          Call (201) 599-1888
        </a>
      </div>
    </div>
  </section>
</MainLayout>
