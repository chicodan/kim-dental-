---
import MainLayout from "../../layouts/MainLayout.astro";
import BookAppointmentButton from "../../components/BookAppointmentButton.astro";
import { LOCALES, type Locale } from "../../i18n/locales";
import { setLocale } from "../../paraglide/runtime.js";

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
setLocale(lang);

const firstVisitSteps = [
  {
    number: "01",
    title: "Arrive & Check In",
    time: "5–10 min",
    description:
      "Our front desk team will welcome you, verify your insurance, and get you settled. New patients will complete a brief health history form — you can also download and fill it out ahead of time.",
  },
  {
    number: "02",
    title: "Digital X-Rays",
    time: "10–15 min",
    description:
      "We take full-mouth digital radiographs to get a clear picture of your teeth, roots, and bone structure. Our digital system uses significantly less radiation than traditional X-rays.",
  },
  {
    number: "03",
    title: "Comprehensive Exam",
    time: "15–20 min",
    description:
      "Dr. Kim personally examines your teeth, gums, bite, and jaw. He also performs an oral cancer screening — a quick, painless visual check of your lips, tongue, cheeks, and throat.",
  },
  {
    number: "04",
    title: "Professional Cleaning",
    time: "30–45 min",
    description:
      "Our hygienist gently removes plaque and tartar buildup that brushing alone can't reach. Your teeth are polished and flossed, leaving your mouth feeling fresh and clean.",
  },
  {
    number: "05",
    title: "Treatment Plan Discussion",
    time: "10–15 min",
    description:
      "Dr. Kim will walk you through everything he found — what's healthy, what needs attention, and what can wait. He answers all your questions without pressure, and you decide what to do next.",
  },
  {
    number: "06",
    title: "Schedule Your Next Visit",
    time: "5 min",
    description:
      "Before you leave, we'll book your next cleaning and any follow-up appointments you need. Most patients are in and out within 90 minutes for their first visit.",
  },
];

const whatToBring = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
    label: "Dental insurance card",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"/></svg>`,
    label: "Photo ID",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>`,
    label: "List of current medications & allergies",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>`,
    label: "Previous dental records (if available)",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>`,
    label: "Payment method for co-pays",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    label: "Any questions you'd like answered",
  },
];

const insurancePlans = [
  "Delta Dental", "MetLife", "Cigna", "United Concordia",
  "Aetna", "Guardian", "Humana", "Blue Cross Blue Shield",
  "Most Major PPOs",
];
---

<MainLayout>

  <!-- ── Hero ──────────────────────────────────────────────────────── -->
  <section class="section-breakout bg-brand-purple py-16">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <p class="text-accent-gold font-medium uppercase tracking-widest text-sm mb-3">
        Patient Center
      </p>
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4">
        We're So Glad You're Here
      </h1>
      <p class="text-white/80 text-lg max-w-2xl mx-auto">
        Whether it's your first visit or your fiftieth, here's everything you need to know about your experience at Kim Dental in Paramus, NJ.
      </p>
    </div>
  </section>

  <!-- ── First Visit Steps ─────────────────────────────────────────── -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-accent-teal font-medium uppercase tracking-widest text-sm mb-2">Step by Step</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-brand-purple">
          What Happens at Your First Visit
        </h2>
        <p class="text-gray-600 mt-3 max-w-xl mx-auto">
          A typical new patient appointment runs about 90 minutes. Here's exactly what to expect from start to finish.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {firstVisitSteps.map((step) => (
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 flex flex-col gap-3 hover:shadow-md transition-shadow">
            <div class="flex items-start justify-between">
              <span class="font-heading text-4xl font-bold text-brand-purple/15 leading-none">
                {step.number}
              </span>
              <span class="text-xs font-medium bg-accent-teal/10 text-accent-teal px-2.5 py-1 rounded-full">
                {step.time}
              </span>
            </div>
            <h3 class="font-heading text-lg font-semibold text-brand-purple">{step.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── What to Bring + Insurance ────────────────────────────────── -->
  <section class="section-breakout bg-brand-light py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

        <!-- What to Bring -->
        <div>
          <p class="text-accent-teal font-medium uppercase tracking-widest text-sm mb-2">Be Prepared</p>
          <h2 class="font-heading text-3xl font-bold text-brand-purple mb-6">What to Bring</h2>
          <ul class="space-y-3">
            {whatToBring.map((item) => (
              <li class="flex items-center gap-4 bg-white rounded-xl px-4 py-3 shadow-sm border border-gray-100">
                <span class="text-accent-teal flex-shrink-0" set:html={item.icon} />
                <span class="text-gray-700 text-sm font-medium">{item.label}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Insurance & Payment -->
        <div>
          <p class="text-accent-teal font-medium uppercase tracking-widest text-sm mb-2">No Surprises</p>
          <h2 class="font-heading text-3xl font-bold text-brand-purple mb-3">Insurance & Payment</h2>
          <p class="text-gray-600 text-sm leading-relaxed mb-6">
            We accept most major PPO insurance plans and work with your provider to maximize your benefits. Our team will review your coverage before treatment so you always know your out-of-pocket costs upfront.
          </p>

          <div class="flex flex-wrap gap-2 mb-6">
            {insurancePlans.map((plan) => (
              <span class="bg-white border border-gray-200 text-gray-700 text-sm px-3 py-1.5 rounded-lg shadow-sm font-medium">
                {plan}
              </span>
            ))}
          </div>

          <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
            <h3 class="font-semibold text-brand-purple mb-3 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
              </svg>
              Payment Options
            </h3>
            <ul class="text-sm text-gray-600 space-y-1.5">
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-accent-teal"></span>
                Cash, check, and all major credit cards
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-accent-teal"></span>
                Flexible payment plans available
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-accent-teal"></span>
                CareCredit and third-party financing accepted
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-accent-teal"></span>
                No surprises — costs reviewed before treatment
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Dental Anxiety ────────────────────────────────────────────── -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="bg-brand-purple rounded-3xl p-8 md:p-12 grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div>
          <p class="text-accent-gold font-medium uppercase tracking-widest text-sm mb-3">You're Not Alone</p>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-4">
            Nervous About Your Visit?
          </h2>
          <p class="text-white/80 leading-relaxed mb-4">
            Dental anxiety is incredibly common — and completely valid. At Kim Dental, we've helped hundreds of nervous patients get the care they need comfortably and confidently.
          </p>
          <p class="text-white/80 leading-relaxed">
            Dr. Kim is known for his calm, gentle demeanor and never-rushed approach. If you're anxious, just let us know when you call or arrive. We'll take extra time to explain every step, answer your questions, and check in with you throughout your appointment.
          </p>
        </div>
        <div class="space-y-4">
          {[
            { title: "We explain everything", body: "Before we do anything, we tell you what's happening and why. No surprises." },
            { title: "We move at your pace", body: "Need a break? Just raise your hand. We'll always pause and check in." },
            { title: "Gentle technique", body: "Dr. Kim's patients consistently say they felt little to no discomfort, even during procedures they feared." },
            { title: "No judgment, ever", body: "Anxious patients sometimes avoid the dentist for years. We understand — and we're glad you're here." },
          ].map((item) => (
            <div class="bg-white/10 border border-white/15 rounded-xl px-5 py-4">
              <h3 class="font-semibold text-white text-sm mb-1">{item.title}</h3>
              <p class="text-white/70 text-sm leading-relaxed">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Office Amenities ──────────────────────────────────────────── -->
  <section class="section-breakout bg-brand-light py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-10">
        <p class="text-accent-teal font-medium uppercase tracking-widest text-sm mb-2">Our Office</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-brand-purple">
          Designed for Your Comfort
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
            title: "Digital Technology",
            body: "State-of-the-art digital X-rays and diagnostic tools for faster, more accurate results with minimal radiation.",
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>`,
            title: "Bilingual Staff",
            body: "Our team is fluent in both English and Korean, so you can always communicate comfortably.",
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
            title: "Easy to Find",
            body: "Located at 275 Forest Ave #110, Paramus — just minutes from Routes 4, 17, and 208 with on-site parking.",
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
            title: "Extended Hours",
            body: "Open Monday–Saturday, including Tuesday evenings until 7 PM, so you can find a time that fits your schedule.",
          },
        ].map((amenity) => (
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 text-center hover:shadow-md transition-shadow">
            <div class="text-accent-teal flex justify-center mb-4" set:html={amenity.icon} />
            <h3 class="font-heading font-semibold text-brand-purple mb-2">{amenity.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{amenity.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FAQ ───────────────────────────────────────────────────────── -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-10">
        <p class="text-accent-teal font-medium uppercase tracking-widest text-sm mb-2">FAQ</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-brand-purple">
          Common Questions
        </h2>
      </div>
      <div class="max-w-3xl mx-auto space-y-4">
        {[
          {
            q: "Do I need to fill out paperwork before my first visit?",
            a: "We'll have new patient forms ready for you at the office. If you'd like to save time, call us at (201) 599-1888 and we can email the forms to you in advance.",
          },
          {
            q: "What if I haven't been to the dentist in a long time?",
            a: "You're in good hands. We see patients who haven't been to the dentist in years — even decades. There's zero judgment here. We'll assess where things stand and create a plan that works for you at your own pace.",
          },
          {
            q: "How long will my first appointment take?",
            a: "Most new patient appointments are 60–90 minutes. This includes X-rays, a full exam, a cleaning, and time to discuss your treatment plan. We'll let you know before you arrive so you can plan accordingly.",
          },
          {
            q: "Can I bring my children?",
            a: "Absolutely — we're a family practice and see patients of all ages. We recommend bringing children in for their first visit around age one, or when their first tooth appears.",
          },
          {
            q: "What if I have a dental emergency?",
            a: "Call us at (201) 599-1888 as soon as possible. We make every effort to see emergency patients the same day. If it's after hours and urgent, our voicemail will provide guidance.",
          },
        ].map((item) => (
          <details class="bg-white border border-gray-100 rounded-xl shadow-sm group">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer font-medium text-gray-800 hover:text-brand-purple transition-colors list-none">
              {item.q}
              <svg class="w-5 h-5 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm text-gray-600 leading-relaxed border-t border-gray-50 pt-3">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────────────────── -->
  <section class="section-breakout bg-brand-purple py-14">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">
        Ready to Schedule Your Visit?
      </h2>
      <p class="text-white/80 text-lg mb-8 max-w-xl mx-auto">
        We'd love to welcome you to the Kim Dental family. Book online or give us a call — we're here Monday through Saturday.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`/${lang}/book`}
          class="inline-flex items-center justify-center gap-2 bg-accent-gold text-white px-7 py-3.5 rounded-lg font-semibold hover:bg-opacity-90 transition-colors"
        >
          Book an Appointment
        </a>
        <a
          href="tel:+12015991888"
          class="inline-flex items-center justify-center gap-2 bg-white/10 border border-white/30 text-white px-7 py-3.5 rounded-lg font-semibold hover:bg-white/20 transition-colors"
        >
          Call (201) 599-1888
        </a>
      </div>
    </div>
  </section>

</MainLayout>
