---
import MainLayout from "../../layouts/MainLayout.astro";
import { LOCALES, type Locale } from "../../i18n/locales";
import { setLocale } from "../../paraglide/runtime.js";
import * as m from "../../paraglide/messages.js";
import { Image } from "astro:assets";
import lobbyImage from "../../assets/images/lobby.jpg";

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
setLocale(lang);
---

<MainLayout>
  <div class="max-w-6xl mx-auto px-4 pt-20 pb-12">
    <!-- Page Header -->
    <header class="mb-8 md:mb-12" data-header>
      <div class="w-16 h-1 bg-accent-teal mb-4 md:mb-6 rounded-full"></div>
      <h1
        class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-brand-purple mb-4 md:mb-6"
      >
        {m.book_page_title()}
      </h1>
      <p class="text-base md:text-lg text-ink-weak max-w-3xl leading-relaxed">
        {m.book_online_coming_soon()}
      </p>
    </header>

    <!-- Main Content Grid -->
    <div
      class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 lg:gap-16 mb-16"
    >
      <!-- Contact Information Section - appears first on mobile -->
      <div class="flex flex-col justify-center order-1" data-contact-section>
        <h2
          class="text-xl md:text-2xl lg:text-3xl font-heading font-bold text-brand-purple mb-4 md:mb-6"
        >
          Get in Touch
        </h2>
        <p
          class="text-base md:text-lg text-ink-weak mb-4 md:mb-6 leading-relaxed"
        >
          Ready to schedule your appointment? Contact us directly:
        </p>

        <div class="space-y-3 md:space-y-4 mb-6 md:mb-8">
          <div class="flex items-center">
            <svg
              class="w-5 h-5 md:w-6 md:h-6 mr-3 md:mr-4 text-accent-teal flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
            <a
              href="tel:201-599-1888"
              class="text-base md:text-lg text-accent-teal hover:text-accent-teal-dark font-semibold transition-colors duration-300"
              >201-599-1888</a
            >
          </div>

          <div class="flex items-center">
            <svg
              class="w-5 h-5 md:w-6 md:h-6 mr-3 md:mr-4 text-accent-teal flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            <a
              href="mailto:sookimdental@gmail.com"
              class="text-base md:text-lg text-accent-teal hover:text-accent-teal-dark font-semibold transition-colors duration-300"
              >sookimdental@gmail.com</a
            >
          </div>
        </div>

        <p class="text-sm text-ink-weak/80 leading-relaxed">
          {m.book_look_forward()}
        </p>
      </div>

      <!-- Image Section - appears second on mobile, second on desktop -->
      <div class="order-2" data-image-section>
        <div
          class="aspect-[4/3] max-w-md mx-auto md:max-w-none rounded-lg overflow-hidden border-2 border-accent-teal/20"
        >
          <Image
            src={lobbyImage}
            alt="Book Appointment"
            widths={[400, 600, 800, 1200]}
            sizes="(max-width: 768px) calc(100vw - 2rem), 50vw"
            format="webp"
            quality="high"
            priority={true}
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Check for reduced motion preference
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if (!prefersReducedMotion) {
    // Animate page header on load
    const header = document.querySelector("[data-header]");
    gsap.from(header, {
      opacity: 0,
      y: 30,
      duration: 1,
      ease: "power3.out",
      delay: 0.2,
    });

    // Animate image section
    const imageSection = document.querySelector("[data-image-section]");
    if (imageSection) {
      gsap.from(imageSection, {
        opacity: 0,
        x: -40,
        duration: 0.8,
        ease: "power2.out",
        scrollTrigger: {
          trigger: imageSection,
          start: "top 80%",
          toggleActions: "play none none none",
        },
      });
    }

    // Animate contact section
    const contactSection = document.querySelector("[data-contact-section]");
    if (contactSection) {
      gsap.from(contactSection, {
        opacity: 0,
        x: 40,
        duration: 0.8,
        ease: "power2.out",
        scrollTrigger: {
          trigger: contactSection,
          start: "top 80%",
          toggleActions: "play none none none",
        },
      });
    }

    // Animate form section
    const formSection = document.querySelector("[data-form-section]");
    if (formSection) {
      gsap.from(formSection, {
        opacity: 0,
        y: 30,
        duration: 0.8,
        ease: "power2.out",
        scrollTrigger: {
          trigger: formSection,
          start: "top 80%",
          toggleActions: "play none none none",
        },
      });
    }
  } else {
    // For users with reduced motion preference, just show everything
    gsap.set(
      "[data-header], [data-image-section], [data-contact-section], [data-form-section]",
      {
        opacity: 1,
        x: 0,
        y: 0,
      },
    );
  }
</script>
