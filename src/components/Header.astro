---
// import LanguageSwitcher from './LanguageSwitcher.astro'; // Temporarily disabled - Korean not ready for launch
import { getLocale } from "../paraglide/runtime.js";
import * as m from "../paraglide/messages.js";
import type { Locale } from "../i18n/locales";

// Force English-only mode - Korean not ready for launch
// Runtime override handled in locales.ts

const currentLocale = getLocale() as Locale;
const localePrefix = `/${currentLocale}`;

const navLinks = [
  { name: m.nav_home(), href: `${localePrefix}/` },
  { name: m.nav_about(), href: `${localePrefix}/about` },
  { name: m.nav_services(), href: `${localePrefix}/services` },
  { name: m.nav_contact(), href: `${localePrefix}/contact` },
];
---

<style>
  .dropdown-parent {
    position: relative;
  }
  .dropdown-caret {
    margin-left: 0.3em;
    font-size: 0.8em;
    vertical-align: middle;
    transition: transform 0.2s ease;
  }
  .dropdown-menu {
    min-width: 220px;
    padding: 0.75rem 0;
    pointer-events: none;
    opacity: 0;
    transition:
      opacity 0.2s ease-in-out,
      transform 0.2s ease-in-out;
    transform: translateY(10px);
  }
  .dropdown-parent:hover .dropdown-menu,
  .dropdown-parent:focus-within .dropdown-menu {
    opacity: 1 !important;
    pointer-events: auto !important;
    transform: translateY(0);
  }
  .dropdown-parent:hover .dropdown-caret {
    transform: rotate(180deg);
  }
  /* Extend the hoverable area to bridge the gap */
  .dropdown-parent::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 8px;
    pointer-events: auto;
  }

  /* Header scroll behavior */
  header {
    position: sticky;
    top: 0;
    will-change: transform;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    transform: translateY(0);
  }
  header.header-hidden {
    transform: translateY(-100%);
  }
</style>

<header class="bg-white shadow-md z-50">
  <div class="mx-auto flex items-center justify-between px-4 py-4 max-w-6xl">
    <a
      href={`${localePrefix}/`}
      class="font-heading text-2xl font-bold text-brand-purple whitespace-nowrap mr-4"
      >Soo B Kim, DDS</a
    >

    <div class="flex items-center gap-4">
      <!-- Mobile action buttons (icons only) -->
      <div class="flex items-center gap-3 md:hidden">
        <a
          href={`${localePrefix}/book`}
          class="text-brand-purple hover:text-accent-teal transition-colors"
          aria-label="Book Now"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
            ></path>
          </svg>
        </a>
        <a
          href="tel:+1234567890"
          class="text-brand-purple hover:text-accent-teal transition-colors"
          aria-label="Call Us"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path>
          </svg>
        </a>
      </div>

      <button
        id="menu-toggle"
        class="md:hidden focus:outline-none text-brand-purple"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16m-7 6h7"></path>
        </svg>
      </button>

      <nav id="menu" class="hidden md:flex items-center gap-3 lg:gap-6">
        <ul class="flex space-x-4 lg:space-x-8">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-gray-800 hover:text-accent-teal transition-colors font-medium"
                >
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
        <div class="flex items-center gap-3">
          <a
            href={`${localePrefix}/book`}
            class="bg-accent-teal text-white px-4 py-2 rounded-md hover:bg-opacity-90 transition-colors font-medium whitespace-nowrap"
          >
            Book Now
          </a>
          <a
            href="tel:+1234567890"
            class="bg-brand-purple text-white px-4 py-2 rounded-md hover:bg-opacity-90 transition-colors font-medium whitespace-nowrap"
          >
            Call Us
          </a>
        </div>
      </nav>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden">
    <ul class="flex flex-col space-y-2 p-4 bg-white shadow-md">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-gray-800 hover:text-accent-teal transition-colors block py-2 font-medium"
            >
              {link.name}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");

  menuToggle?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  // Header scroll behavior - hide when scrolling down, show when scrolling up
  let lastScrollY = window.scrollY;
  let ticking = false;
  const scrollThreshold = 10; // Minimum scroll distance to trigger hide/show
  const hideAfter = 100; // Only start hiding after scrolling this many pixels

  const header = document.querySelector("header") as HTMLElement;

  function updateHeaderVisibility() {
    const currentScrollY = window.scrollY;
    const scrollDifference = currentScrollY - lastScrollY;

    // Only update if scroll difference is significant (hysteresis)
    if (Math.abs(scrollDifference) < scrollThreshold) {
      ticking = false;
      return;
    }

    const scrollingDown = scrollDifference > 0;
    const pastThreshold = currentScrollY > hideAfter;

    if (scrollingDown && pastThreshold) {
      // Scrolling down and past threshold - hide header
      header?.classList.add("header-hidden");
    } else if (!scrollingDown) {
      // Scrolling up - show header
      header?.classList.remove("header-hidden");
    }

    // If at the very top, always show header
    if (currentScrollY <= hideAfter) {
      header?.classList.remove("header-hidden");
    }

    lastScrollY = currentScrollY;
    ticking = false;
  }

  window.addEventListener(
    "scroll",
    () => {
      if (!ticking) {
        window.requestAnimationFrame(updateHeaderVisibility);
        ticking = true;
      }
    },
    { passive: true },
  );
</script>
